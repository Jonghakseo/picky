#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

HOST_ARCH="$(uname -m)"
DESTINATION="${PICKY_XCODE_DESTINATION:-platform=macOS,arch=${HOST_ARCH}}"

echo "🔎 pre-push: verifying Picky app build..."
xcodebuild -project Picky.xcodeproj -scheme Picky -destination "$DESTINATION" build

echo "🧪 pre-push: running Picky test suite..."
xcodebuild -project Picky.xcodeproj -scheme Picky -destination "$DESTINATION" test

echo "✅ pre-push: build and tests passed."
