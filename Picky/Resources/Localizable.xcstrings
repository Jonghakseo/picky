    "settings.azure.realtimeUrlNote": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste the full Azure Realtime URL. Picky derives deployment, API version, and preview/GA shape from it."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Azure Realtime URL 전체를 붙여넣어주세요. Picky가 deployment, API 버전, preview/GA 형식을 자동으로 파악해요."
          }
        }
      }
    },
    "settings.azure.ttsUrlNote": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TTS should use the /audio/speech URL. It can share the same Azure resource and key as STT, but usually has its own deployment. The model/deployment is parsed from the URL."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "TTS는 /audio/speech URL을 사용해주세요. STT와 같은 Azure 리소스·키를 공유할 수 있지만 보통 자체 deployment을 사용해요. 모델/deployment은 URL에서 자동으로 파싱돼요."
          }
        }
      }
