    },
    "onboarding.bubble.delegatingToPickle": {
      "comment": "Picky speaks the prompt it would send to a Pickle. 'Hey Pickle' opens the line; keep it bolded as the attention marker.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "'**Hey Pickle** вАФ can you summarize this page and write it up for me? Focus on the part they marked.'"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'**Hey Pickle** вАФ мЭі нОШмЭімІА мЪФмХљнХімДЬ м†Хл¶ђнХі м§ДлЮШмЪФ? нСЬмЛЬнХЬ лґАлґД мЬДм£Љл°ЬмЪФ.'"
          }
        }
      }
    },
    "onboarding.bubble.explainingDelegation": {
      "comment": "Sets up the idea of delegating to a Pickle.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For a page like this I can answer inline, or I can hand the work off to a **Pickle** in the dock."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мЭілЯ∞ нОШмЭімІАлКФ м†Ьк∞А л∞Фл°Ь лЛµнХ† мИШлПД мЮИк≥†, лПДнБђмЭШ **Pickle** мЧР мЮСмЧЕмЭД лІ°кЄЄ мИШлПД мЮИмЦімЪФ."
          }
        }
      }
    },
    "onboarding.bubble.explainingPickle": {
      "comment": "Short definition of what a Pickle is. The bold phrase emphasises that a Pickle is an independent Pi session.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pickle is an independent **Pi session** that runs in your dock вАФ like a background tab for long work."
          }
        },
