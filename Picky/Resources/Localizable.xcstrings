    "settings.field.reasoningLevel.pickleNote": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used only as the initial reasoning level for newly-created Pickles. Running Pickles can still cycle it independently."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새로 생성되는 Pickle의 초기 추론 레벨로만 사용돼요. 실행 중인 Pickle은 독립적으로 변경할 수 있어요."
          }
        }
      }
    },
    "settings.field.screenContext": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
