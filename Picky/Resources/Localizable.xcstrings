    "onboarding.bubble.awaitingArchive": {
      "comment": "Asks the user to actually perform the long-press archive gesture now. Shows after the inviteArchive intro bubble has had its reading dwell.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Now **long-press** the demo pickle to archive it."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이제 데모 Pickle을 **길게 눌러** 아카이브해 보세요."
          }
        }
      }
    },
    "onboarding.bubble.awaitingPickleOpen": {
      "comment": "Reminder to perform the dock-card open action.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**Open the dock pickle** to keep going."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**도크의 Pickle을 열어** 서 계속 진행해 주세요."
          }
        }
      }
    },
    "onboarding.bubble.delegatingToPickle": {
      "comment": "Picky speaks the prompt it would send to a Pickle. 'Hey Pickle' opens the line; keep it bolded as the attention marker.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "'**Hey Pickle** — can you summarize this page and write it up for me? Focus on the part they marked.'"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'**Hey Pickle** — 이 페이지 요약해서 정리해 줄래요? 표시한 부분 위주로요.'"
          }
        }
      }
    },
    "onboarding.bubble.explainingDelegation": {
      "comment": "Sets up the idea of delegating to a Pickle.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For a page like this I can answer inline, or I can hand the work off to a **Pickle** in the dock."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이런 페이지는 제가 바로 답할 수도 있고, 도크의 **Pickle** 에 작업을 맡길 수도 있어요."
          }
        }
      }
    },
    "onboarding.bubble.explainingPickle": {
      "comment": "Short definition of what a Pickle is. The bold phrase emphasises that a Pickle is an independent Pi session.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pickle is an independent **Pi session** that runs in your dock — like a background tab for long work."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickle은 도크에서 도는 독립된 **Pi 세션** 이에요 — 긴 작업을 위한 백그라운드 탭 같은 거죠."
          }
        }
      }
    },
    "onboarding.bubble.explainingTriggers": {
      "comment": "Explains the two shortcuts for talking to Picky. Each shortcut combo is bolded as one unit; the watch-only line is bolded as a third unit.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can talk to me with **Push-to-Talk (Control+Option)** or **Quick Input (double-tap Control)**. **For this demo I'll drive — just watch.**"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저를 부를 때는 **눌러서 말하기(Control+Option)** 또는 **퀵 인풋(Control 더블탭)을** 쓰면 돼요. **이번 데모는 제가 진행할 테니 편하게 보세요.**"
          }
        }
      }
    },
    "onboarding.bubble.introducing": {
      "comment": "Picky greets the user. Brand name 'Picky' stays as-is in every language and is highlighted.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I'm **Picky**. I follow your cursor and help you get things done — right where you're working."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "안녕하세요! 저는 **Picky** 예요. 작업하는 바로 그 자리에서 커서를 따라다니며 도와드릴게요."
          }
        }
      }
    },
    "onboarding.bubble.inviteArchive": {
      "comment": "Introduces the long-press archive gesture.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you're done with a Pickle, **long-press** it to archive."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickle을 다 썼다면 **길게 누르기** 로 아카이브할 수 있어요."
          }
        }
      }
    },
    "onboarding.bubble.inviteClose": {
      "comment": "Asks the user to click the dock pickle again to close it.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Now **click the pickle in the dock again** to close it."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이제 **도크의 Pickle을 다시 클릭** 해서 닫아주세요."
          }
        }
      }
    },
    "onboarding.bubble.inviteDrawing": {
      "comment": "Invites the user to draw a highlight on the page. Bolded phrase is the gesture they have to perform.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Want to highlight something? **Click and draw a circle** anywhere on the patch notes to mark a region."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "강조하고 싶은 부분이 있나요? 패치노트 어디서든 **클릭 후 동그라미를 그려서** 영역을 표시해 보세요."
          }
        }
      }
    },
    "onboarding.bubble.openedPickle": {
      "comment": "Explains follow-up + terminal switch inside a Pickle. Bolded phrase is the keystroke (⌘T) plus the action.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inside a Pickle you can send follow-up messages or **switch to the terminal UI (⌘T)** to keep working."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickle 안에서는 후속 메시지를 보내거나, **터미널 UI로도 전환(⌘T)** 해서 사용할 수 있어요."
          }
        }
      }
    },
    "onboarding.bubble.openingPatchNotes": {
      "comment": "Picky opens the patch notes URL. Bolded phrase is the specific release name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opening **Pi 0.73.1 release notes** in your browser…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**Pi 0.73.1 릴리즈 노트** 를 브라우저에서 열고 있어요…"
          }
        }
      }
    },
    "onboarding.bubble.outro": {
      "comment": "Closing bubble. Tells the user to ask Picky about usage; bolded phrases are the two shortcut combos to remember.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nice. If you’re unsure how to use Picky, just ask me — I can answer from Picky’s built-in guide. Call me anytime with **Push-to-Talk (Control+Option)** or **Quick Input (double-tap Control)**."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "좋아요. Picky 사용법이 궁금하면 언제든 저에게 물어보세요. Picky의 내장 가이드를 바탕으로 알려드릴게요. **눌러서 말하기(Control+Option)** 또는 **퀵 인풋(Control 더블탭)** 으로 저를 불러주세요."
          }
        }
      }
    },
    "onboarding.bubble.pickleCompleted": {
      "comment": "Pickle finished. Bolded phrase tells the user which action to take next.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickle is done! **Click the pickle** in your dock to inspect what it produced."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickle이 끝났어요! 도크에서 **Pickle을 클릭** 해서 결과를 확인해 보세요."
          }
        }
      }
    },
    "onboarding.bubble.pickleRunning": {
      "comment": "Pickle is working. Bolded phrase reminds the user that their highlight is the context being used.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "While the Pickle works, notice how **your highlighted area** gets carried along as context — see the preview above."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickle이 일하는 동안 **표시해 둔 영역** 이 컨텍스트로 같이 따라가는걸 위 미리보기에서 확인할 수 있어요."
          }
        }
      }
    },
    "onboarding.bubble.preWelcome": {
      "comment": "First onboarding bubble. **bold** markers wrap the phrase that gets the amber highlight; keep markers around the same idea in every language (here: that it makes no real LLM calls).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This onboarding **never makes real LLM calls**. Relax and follow along."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 온보딩은 **실제 LLM 호출을 하지 않아요**. 편하게 따라와 주세요."
          }
        }
      }
    },
    "onboarding.bubble.showingCapabilities": {
      "comment": "Sets up the next beat where Picky opens Pi's release notes.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There is a bunch of things I can do. For example, I can pull up Pi's release notes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저는 여러 가지 일을 할 수 있어요. 예를 들면 Pi의 릴리즈 노트를 띄워줄 수 있죠."
          }
        }
      }
    },
    "onboarding.highlight.header": {
      "comment": "Header of the floating panel that previews the screen capture sent with the highlighted region.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is what gets sent as context"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이게 컨텍스트로 전송되는 내용이에요"
          }
        }
      }
    },
    "onboarding.scenario.finalAnswer": {
      "comment": "The Pickle's final answer rendered as markdown. Preserve the **bold** title and the bullet/code formatting.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**Pi 0.73.1 — 3 highlights**\n\n- `pi update --self` now handles the package rename from `@mariozechner/pi-coding-agent` to `@earendil-works/pi-coding-agent`, so existing global installs migrate via the normal self-update flow.\n- OAuth providers can present multiple login choices through `/login` for provider-specific interactive sign-in.\n- `models.json` now accepts comments and trailing commas (JSONC), making custom provider/model configuration easier to maintain."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "**Pi 0.73.1 — 주요 변경 3가지**\n\n- `pi update --self`가 이제 `@mariozechner/pi-coding-agent`에서 `@earendil-works/pi-coding-agent`로의 패키지 이름 변경을 처리해서, 기존 글로벌 설치도 일반 self-update 흐름으로 자연스럽게 마이그레이션돼요.\n- OAuth 프로바이더가 `/login`을 통해 여러 로그인 선택지를 제공할 수 있어 provider별 대화식 로그인이 가능해졌어요.\n- `models.json`이 이제 주석과 trailing comma(JSONC)를 허용해서, 커스텀 provider/모델 설정 관리가 한결 편해졌어요."
          }
        }
      }
    },
    "onboarding.scenario.summary.extracting": {
      "comment": "Status pill while the demo Pickle is extracting changelog.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extracting changelog"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변경사항 정리 중"
          }
        }
      }
    },
    "onboarding.scenario.summary.queued": {
      "comment": "Status pill shown while the demo Pickle is queued.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Queued"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대기 중"
          }
        }
      }
    },
    "onboarding.scenario.summary.reading": {
      "comment": "Status pill while the demo Pickle is reading the page.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading page"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "페이지 읽는 중"
          }
        }
      }
    },
    "onboarding.scenario.summary.ready": {
      "comment": "Status pill once the demo Pickle finishes.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Summary ready"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "요약 완료"
          }
        }
      }
    },
    "onboarding.scenario.thinking": {
      "comment": "Thinking bubble shown inside the demo Pickle card.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reading pi.dev/news/releases/0.73.1 and pulling out the headline changes…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "pi.dev/news/releases/0.73.1을 읽으면서 핵심 변경사항을 뽑고 있어요…"
          }
        }
      }
    },
    "onboarding.scenario.title": {
      "comment": "Title of the demo Pickle card shown in the dock during onboarding.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Summarize pi.dev/news/releases/0.73.1"
          }
        },
        "ko": {
