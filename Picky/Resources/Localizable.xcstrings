    "settings.general.language.note": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some macOS-owned surfaces (the app menu, system dialogs) only follow this on the next launch. The rest of Picky retranslates immediately."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS가 관리하는 영역(앱 메뉴, 시스템 다이얼로그 등)은 다음 실행부터 적용돼요. 그 외 영역은 즉시 변경돼요."
