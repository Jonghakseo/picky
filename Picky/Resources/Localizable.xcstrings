    },
    "settings.field.attachScreenshotsOnlyWhenInked": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send screenshots only when drawn"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그렸을 때만 화면 첨부"
          }
        }
      }
    },
    "settings.field.attachScreenshotsOnlyWhenInked.note": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, Picky attaches a screenshot only if you marked the screen with click and drag. Screen capture still runs locally for the ink overlay; only the model handoff is skipped."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 클릭&드래그로 화면에 표시한 부분이 있을 때만 스크린샷을 모델로 전달해요. 화면 캡처 자체는 잉크 오버레이 때문에 계속 동작하고, 모델로 보내는 단계만 건너뛰어요."
          }
        }
      }
    },
    "settings.field.screenshotQuality": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screenshot quality"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스크린샷 품질"
          }
        }
      }
    },
    "settings.field.screenshotQuality.note": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Controls the longest screenshot edge sent to Picky. Higher quality improves small text but uses more image tokens."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Picky에 전달되는 스크린샷의 가장 긴 변을 조절해요. 품질이 높을수록 작은 글자가 선명해지지만 이미지 토큰이 더 소요돼요."
          }
        }
      }
    },
    "settings.field.agentsFile": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AGENTS.md"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AGENTS.md"
          }
        }
      }
    },
    "settings.field.agentsFile.note": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edit Picky's persona and Pickle routing rules directly in the AGENTS.md inside the main agent cwd. Pi loads it on every main-agent turn — reset or relaunch Picky to pick up mid-session changes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메인 에이전트 작업 폴더의 AGENTS.md를 직접 편집해서 Picky 페르소나와 Pickle 라우팅 규칙을 바꿔요. Pi가 매 턴마다 이 파일을 읽으며, 세션 중에 적용하려면 Picky를 초기화하거나 재시작해주세요."
          }
        }
      }
    },
