    "settings.oauth.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use these buttons to start Pi OAuth in your browser. Picky stores nothing itself; credentials are written to Pi's local auth storage."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아래 버튼으로 브라우저에서 Pi OAuth 로그인을 시작해요. Picky는 자격 증명을 직접 저장하지 않고, Pi의 로컬 auth storage에 기록합니다."
          }
        }
      }
    },
