    "settings.mainAgentRuntime.restartNotice": {
      "comment": "Format: runtime will switch to <desired runtime>; current session keeps using <applied runtime>.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runtime will switch to %@ after you restart Picky. The current session keeps using %@."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Picky를 재시작하면 런타임이 %@로 전환돼요. 현재 세션은 계속 %@를 사용해요."
          }
