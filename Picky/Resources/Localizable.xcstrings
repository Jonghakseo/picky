{
  "sourceLanguage": "en",
  "strings": {
    "agent.summary.pointingScreen": {
      "comment": "Format: 'Pointing at: <label>'. Arg is the element label.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pointing at: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가리키는 중: %@"
          }
        }
      }
    },
    "agent.summary.pointingScreenAnon": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pointing at the screen…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면 위치를 가리키는 중…"
          }
        }
      }
    },
    "agent.summary.preparingResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preparing response…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "응답 준비 중…"
          }
        }
      }
    },
    "common.findApp": {
      "comment": "Button that reveals Picky in Finder so the user can drag it into a system permission list.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find App"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 위치 찾기"
          }
        }
      }
    },
    "common.grant": {
      "comment": "Generic 'Grant' button label used by every permission row.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "허용하기"
          }
        }
      }
    },
    "common.granted": {
      "comment": "Status pill shown when a permission is granted.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Granted"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "허용됨"
          }
        }
      }
    },
    "common.install": {
      "comment": "Generic 'Install' button (opens an install destination in a browser).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설치하기"
          }
        }
      }
    },
    "common.quit": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "종료"
          }
        }
      }
    },
    "common.ready": {
      "comment": "Status pill for non-permission readiness.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ready"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "준비됨"
          }
        }
      }
    },
    "common.recheck": {
      "comment": "Re-run a local check for something Picky depends on.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recheck"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다시 확인"
          }
        }
      }
    },
    "common.save": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save changes"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변경사항 저장"
          }
        }
      }
    },
    "common.saved": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장됨"
          }
        }
      }
    },
    "dictation.noSpeech": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No speech detected. Press and hold the button a little longer while speaking."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성이 감지되지 않았어요. 버튼을 누른 상태에서 조금 더 길게 말해 주세요."
          }
        }
      }
    },
    "directMessage.steerDelivered": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delivered the steering message to the selected Pickle."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 Pickle에 메시지를 전달했어요."
          }
        }
      }
    },
    "error.directMessage.contextEmpty": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t send message: Context capture returned no packet."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메시지를 전송하지 못했어요: 캡처된 컨텍스트가 비어있어요."
          }
        }
      }
    },
    "error.directMessage.deliverFailed": {
      "comment": "Format: 'Couldn't deliver message: <reason>'.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t deliver message: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메시지를 전달하지 못했어요: %@"
          }
        }
      }
    },
    "error.directMessage.fallback": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t send the message."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메시지를 보내지 못했어요."
          }
        }
      }
    },
    "error.directMessage.sendFailed": {
      "comment": "Format: 'Couldn't send message: <reason>'. Arg is the reason from the daemon.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t send message: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메시지를 전송하지 못했어요: %@"
          }
        }
      }
    },
    "error.directMessage.startFailed": {
      "comment": "Format: 'Couldn't start a new message session: <reason>'.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t start a new message session: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 메시지 세션을 시작하지 못했어요: %@"
          }
        }
      }
    },
    "feedback.addFiles": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add files…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일 추가…"
          }
        }
      }
    },
    "feedback.attachmentsHint": {
      "comment": "Format args: 1) max count integer 2) per-file size string 3) total size string.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Up to %1$lld files, %2$@ each, %3$@ total."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 항목이에요. 파일 최대 %1$lld개, 개별 %2$@, 합계 %3$@까지."
          }
        }
      }
    },
    "feedback.field.attach": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Attach files"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일 첨부"
          }
        }
      }
    },
    "feedback.field.category": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Category"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카테고리"
          }
        }
      }
    },
    "feedback.field.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Message"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내용"
          }
        }
      }
    },
    "feedback.notConfigured": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback channel not configured yet."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드백 채널이 아직 설정되지 않았어요."
          }
        }
      }
    },
    "feedback.placeholder": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What happened, or what were you hoping for?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무슨 일이 있었나요? 어떤 게 필요하셨나요?"
          }
        }
      }
    },
    "feedback.send": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보내기"
          }
        }
      }
    },
    "feedback.sending": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sending…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보내는 중…"
          }
        }
      }
    },
    "feedback.sent": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sent — thanks!"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보냈어요 — 고마워요!"
          }
        }
      }
    },
    "footer.quit.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Picky will stop running in the menu bar and ongoing local sessions may be interrupted."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Picky가 메뉴바에서 종료되며, 진행 중인 로컬 세션이 중단될 수 있어요."
          }
        }
      }
    },
    "hud.archiveToast.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Session archived"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션을 아카이브했어요"
          }
        }
      }
    },
    "hud.archiveToast.undo": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Undo"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "되돌리기"
          }
        }
      }
    },
    "hud.compact.done.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Older context was summarized. The agent can continue with a cleaner transcript."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 컨텍스트를 요약했어요. 에이전트가 더 깔끔한 대화로 이어갈 수 있어요."
          }
        }
      }
    },
    "hud.compact.done.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Session compacted"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션이 압축됐어요"
          }
        }
      }
    },
    "hud.compact.failed.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-compaction failed"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 압축에 실패했어요"
          }
        }
      }
    },
    "hud.compact.running": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compacting…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대화 압축하는 중…"
          }
        }
      }
    },
    "hud.composer.steerTarget": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next Picky screen input will go to this Pickle"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 Picky 화면 입력은 이 Pickle로 전달돼요"
          }
        }
      }
    },
    "hud.conversation.clearAll": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear all"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모두 지우기"
          }
        }
      }
    },
    "hud.conversation.viewAsTui": {
      "comment": "Hint above a hidden-history fold. Format arg is the integer count of hidden older messages. Opens the Pi terminal overlay panel.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Pi terminal · %lld more"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "TUI창으로 전체 대화 보기 · %lld개 더"
          }
        }
      }
    },
    "hud.inlineTerminal.failed.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pi terminal could not start"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pi 터미널을 시작할 수 없어요"
          }
        }
      }
    },
    "hud.inlineTerminal.singleton.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Close the active TUI Pickle, or move the TUI screen here."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 TUI Pickle을 닫거나 TUI 화면을 여기로 옮겨주세요."
          }
        }
      }
    },
    "hud.inlineTerminal.singleton.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TUI can only be open in one Pickle at a time."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "TUI는 한 번에 하나의 Pickle에서만 열 수 있어요."
          }
        }
      }
    },
    "hud.inlineTerminal.tab.chat": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "채팅"
          }
        }
      }
    },
    "hud.inlineTerminal.tab.tui": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TUI"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "TUI"
          }
        }
      }
    },
    "hud.inlineTerminal.unavailable.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Pickle does not have a Pi session file yet."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Pickle에는 아직 Pi 세션 파일이 없어요."
          }
        }
      }
    },
    "hud.inlineTerminal.unavailable.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pi terminal is unavailable"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pi 터미널을 사용할 수 없어요"
          }
        }
      }
    },
    "hud.archivedList.empty": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No archived Pickles."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아카이브된 Pickle이 없어요."
          }
        }
      }
    },
    "hud.archivedList.delete": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제"
          }
        }
      }
    },
    "hud.archivedList.confirmDelete": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap again to delete"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 번 더 누르면 삭제"
          }
        }
      }
    },
    "hud.archivedList.restore": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restore"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복원"
          }
        }
      }
    },
    "hud.archivedList.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived Pickles"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아카이브된 Pickle"
          }
        }
      }
    },
    "hud.archivedList.deleteAll": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete all"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체 삭제"
          }
        }
      }
    },
    "hud.archivedList.confirmDeleteAllTitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permanently delete %lld archived Pickles?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아카이브된 Pickle %lld개를 영구 삭제할까요?"
          }
        }
      }
    },
    "hud.archivedList.confirmDeleteAllMessage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This action cannot be undone. Every archived Pickle is removed from Picky and from the local agent's session store."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 작업은 되돌릴 수 없어요. 모든 아카이브 Pickle이 Picky와 로컬 에이전트 세션 저장소에서 함께 제거돼요."
          }
        }
      }
    },
    "hud.archivedList.confirmDeleteAllConfirm": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete all"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체 삭제"
          }
        }
      }
    },
    "hud.archivedList.confirmDeleteAllCancel": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "취소"
          }
        }
      }
    },
    "hud.menu.archive": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archive"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아카이브"
          }
        }
      }
    },
    "hud.menu.copyResume": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy resume command"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재개 명령 복사"
          }
        }
      }
    },
