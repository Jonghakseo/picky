    "settings.field.piModel.helpText": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose Automatic to follow Pi settings, or pick a model to pin Picky. Reasoning level below is applied with the pinned model."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pi 설정을 따르려면 Automatic을 선택하고, Picky에 고정하려면 모델을 고르세요. 아래의 추론 레벨은 고정 모델과 함께 적용돼요."
          }
        }
      }
    },
    "settings.field.modelOption.automatic": {
