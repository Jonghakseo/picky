            "state": "translated",
            "value": "사용자 가이드 읽기"
          }
        }
      }
    },
    "settings.builtinTools.tool.readUserGuide.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let the agent consult Picky's bundled manual before answering app-usage questions. Disabling makes the agent answer those from general knowledge."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 Picky 사용법 질문에 답하기 전 내장 매뉴얼을 참조하도록 해요. 끄면 일반 지식으로 답해요."
          }
        }
