#!/usr/bin/env python3
"""Extract a turn-level summary of the OpenAI Realtime conversation from the
running Picky agentd's stdout log and open it.

Usage:
    scripts/picky-realtime-dialogue                # extract + open
    scripts/picky-realtime-dialogue --print        # print to stdout, no open
    scripts/picky-realtime-dialogue --tail N       # keep last N realtime lines (default 2000)
    scripts/picky-realtime-dialogue --include-errors
    scripts/picky-realtime-dialogue --no-open

The script always reads
~/Library/Application Support/Picky/Logs/agentd.stdout.log and writes a
filtered, human-readable timeline to
~/Library/Application Support/Picky/Logs/agentd.realtime-dialogue.log.

Output entries (one per turn-relevant event):
- [ts] USER (text|voice[, N img, contentTypes=...]):
  - # Picky turn user request body + captured context + screenshot paths
  - or "(voice audio committed)" for Realtime PTT turns
  - or full text for bootstrap notices, context replay, pickle completion pings
- [ts] PICKY: assistant transcript
- [ts]   ↪ TOOL name(<pretty-printed JSON args>)
- [ts]     ↳ result: <pretty-printed JSON result>
- [ts]   ↩ TOOL name done elapsedMs=... resultChars=...
- [ts]   • response.done status=... totalTokens=... outputTokens=... [+tool]
- [ts] 🔄 SESSION ROLLOVER reason=... age=...min
- [ts] 🔌 WS DISCONNECTED (...)
- [ts] ✓  WS CONNECTED model=... host=...
- [ts] ⚠️  SERVER ERROR ... (only with --include-errors)
"""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path

LOG_DIR = Path.home() / "Library/Application Support/Picky/Logs"
LOG = LOG_DIR / "agentd.stdout.log"
OUT = LOG_DIR / "agentd.realtime-dialogue.log"

TS_RE = re.compile(r"^(\S+) picky-agentd ")


def field(line: str, key: str) -> str | None:
    m = re.search(rf'{key}="((?:[^"\\]|\\.)*)"', line)
    return m.group(1) if m else None


def unesc(s: str | None) -> str | None:
    if s is None:
        return s
    return (
        s.replace("\\n", "\n").replace("\\t", "\t").replace('\\"', '"').replace("\\\\", "\\")
    )


def extract_user_request(text: str | None) -> str:
    if text is None:
        return ""
    text = unesc(text)
    if text.startswith("# Picky turn"):
        m = re.search(r"^## User request", text, re.MULTILINE)
        if m:
            return text[m.start() :].strip()
    if text.startswith("# Picky realtime voice context"):
        m = re.search(r"^- Source:", text, re.MULTILINE)
        if m:
            return "(voice audio committed)\n\n" + text[m.start() :].strip()
        return "(voice audio committed)"
    return text.strip()


def format_tool_args(raw: str | None) -> str:
    if not raw:
        return ""
    s = unesc(raw)
    try:
        obj = json.loads(s)
        return json.dumps(obj, ensure_ascii=False, indent=2)
    except Exception:
        return s


def render_block(out_lines: list[str], ts: str, label: str, body: str | None) -> None:
    body = body or ""
    if "\n" in body:
        out_lines.append(f"[{ts}] {label}:")
        for line in body.split("\n"):
            out_lines.append(f"        {line}")
    else:
        out_lines.append(f"[{ts}] {label}: {body}")


def render_tool_payload(out_lines: list[str], ts: str, head: str, body: str) -> None:
    if "\n" in body or len(body) > 160:
        out_lines.append(f"[{ts}]   {head}")
        for line in body.split("\n"):
            out_lines.append(f"        {line}")
    else:
        # head already carries the inline value
        out_lines.append(f"[{ts}]   {head}{body}")


def build_dialogue(*, tail: int, include_errors: bool) -> list[str]:
    if not LOG.exists():
        raise FileNotFoundError(f"agentd stdout log not found at {LOG}")

    out_lines: list[str] = []
    with LOG.open("r", encoding="utf-8", errors="replace") as f:
        for line in f:
            if "picky-agentd main realtime" not in line:
                continue
            m = TS_RE.match(line)
            ts = m.group(1) if m else "?"

            if 'send conversation.item role="user"' in line:
                text = field(line, "text")
                content = extract_user_request(text)
                source = "voice" if "voice context" in (text or "") else "text"
                images_match = re.search(r"images=(\d+)", line)
                images = int(images_match.group(1)) if images_match else 0
                ctypes = field(line, "contentTypes") or ""
                meta = source
                if images:
                    meta += f", {images} img"
                if ctypes and ctypes != "input_text":
                    meta += f", contentTypes={ctypes}"
                render_block(out_lines, ts, f"USER ({meta})", content)
            elif "recv output_transcript.done" in line:
                transcript = field(line, "transcript")
                if transcript:
                    render_block(out_lines, ts, "PICKY", unesc(transcript))
            elif "tool dispatch" in line:
                tool = field(line, "tool")
                formatted = format_tool_args(field(line, "arguments"))
                if "\n" in formatted or len(formatted) > 160:
                    out_lines.append(f"[{ts}]   ↪ TOOL {tool}(")
                    for arg_line in formatted.split("\n"):
                        out_lines.append(f"        {arg_line}")
                    out_lines.append("      )")
                else:
                    out_lines.append(f"[{ts}]   ↪ TOOL {tool}({formatted})")
            elif "tool done" in line:
                tool = field(line, "tool")
                elapsed = re.search(r"elapsedMs=(\d+)", line)
                result_chars = re.search(r"resultChars=(\d+)", line)
                out_lines.append(
                    f"[{ts}]   ↩ TOOL {tool} done "
                    f"elapsedMs={elapsed.group(1) if elapsed else '?'} "
                    f"resultChars={result_chars.group(1) if result_chars else '?'}"
                )
            elif "send function_call_output" in line:
                formatted = format_tool_args(field(line, "output"))
                if "\n" in formatted or len(formatted) > 160:
                    out_lines.append(f"[{ts}]     ↳ result:")
                    for r_line in formatted.split("\n"):
                        out_lines.append(f"        {r_line}")
                else:
                    out_lines.append(f"[{ts}]     ↳ result: {formatted}")
            elif include_errors and "server error" in line:
                code = field(line, "code")
                etype = field(line, "type")
                msg = field(line, "message")
                out_lines.append(
                    f"[{ts}] ⚠️  SERVER ERROR {etype}/{code}: {(msg or '')[:300]}"
                )
            elif "session rollover" in line:
                reason = field(line, "reason")
                age = re.search(r"ageMs=(\d+)", line)
                age_min = f"{int(age.group(1))/60000:.1f}min" if age else "?"
                out_lines.append(f"[{ts}] 🔄 SESSION ROLLOVER reason={reason} age={age_min}")
            elif "main realtime disconnected" in line:
                msg = field(line, "message")
                out_lines.append(f"[{ts}] 🔌 WS DISCONNECTED ({msg})")
            elif "main realtime connected" in line:
                model = field(line, "modelOrDeployment")
                host = field(line, "endpointHost")
                out_lines.append(f"[{ts}] ✓  WS CONNECTED model={model} host={host}")
            elif "recv response.done" in line:
                status = field(line, "status")
                total = re.search(r"totalTokens=(\d+)", line)
                out_t = re.search(r"outputTokens=(\d+)", line)
                fc = re.search(r"includesFunctionCall=(\d+)", line)
                fc_flag = " +tool" if fc and fc.group(1) == "1" else ""
                out_lines.append(
                    f"[{ts}]   • response.done status={status} "
                    f"totalTokens={total.group(1) if total else '?'} "
                    f"outputTokens={out_t.group(1) if out_t else '?'}{fc_flag}"
                )

    if tail and tail > 0:
        out_lines = out_lines[-tail:]
    return out_lines


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawTextHelpFormatter)
    parser.add_argument("--tail", type=int, default=2000, help="keep only the last N output lines (default: 2000, 0 = all)")
    parser.add_argument("--include-errors", action="store_true", help="include `⚠️  SERVER ERROR` lines (excluded by default)")
    parser.add_argument("--no-open", action="store_true", help="write the file but do not open it")
    parser.add_argument("--print", dest="print_only", action="store_true", help="print to stdout instead of writing/opening")
    args = parser.parse_args()

    try:
        lines = build_dialogue(tail=args.tail, include_errors=args.include_errors)
    except FileNotFoundError as e:
        print(str(e), file=sys.stderr)
        return 1

    if args.print_only:
        sys.stdout.write("\n".join(lines) + "\n")
        return 0

    OUT.write_text("\n".join(lines) + "\n", encoding="utf-8")
    print(f"wrote {len(lines)} lines to {OUT}", file=sys.stderr)

    if not args.no_open:
        subprocess.run(["open", str(OUT)], check=False)
    return 0


if __name__ == "__main__":
    sys.exit(main())
