diff --git a/Picky/Sessions/PickyGitDiffSnapshotLoader.swift b/Picky/Sessions/PickyGitDiffSnapshotLoader.swift
new file mode 100644
index 0000000..b7c4a2e
--- /dev/null
+++ b/Picky/Sessions/PickyGitDiffSnapshotLoader.swift
@@ -0,0 +1,38 @@
+//
+//  PickyGitDiffSnapshotLoader.swift
+//  Picky
+//
+
+import Foundation
+
+struct PickyGitDiffSnapshotLoader {
+    func load(cwd: String) throws -> PickyGitDiffSnapshot {
+        let repoRoot = try git(["rev-parse", "--show-toplevel"], cwd: cwd)
+            .trimmingCharacters(in: .whitespacesAndNewlines)
+        let diff = try workingTreeSnapshotDiff(repoRoot: repoRoot)
+        return PickyGitDiffSnapshot(repoRoot: repoRoot, unifiedDiff: diff)
+    }
+
+    private func workingTreeSnapshotDiff(repoRoot: String) throws -> String {
+        let tempIndex = FileManager.default.temporaryDirectory
+            .appendingPathComponent("picky-diff-\(UUID().uuidString).index")
+        defer { try? FileManager.default.removeItem(at: tempIndex) }
+
+        var env = ProcessInfo.processInfo.environment
+        env["GIT_INDEX_FILE"] = tempIndex.path
+        _ = try git(["read-tree", "HEAD"], cwd: repoRoot, environment: env)
+        _ = try git(["add", "-A", "--", "."], cwd: repoRoot, environment: env)
+        return try git(["diff", "--cached", "--find-renames", "-M", "HEAD", "--"], cwd: repoRoot, environment: env)
+    }
+
+    private func git(_ args: [String], cwd: String, environment: [String: String]? = nil) throws -> String {
+        // Process implementation lives here in the production port.
+        return ""
+    }
+}
